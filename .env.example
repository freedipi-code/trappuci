# --- Telegram ---
BOT_TOKEN=123456:ABCDEF_remplace_par_le_token_BotFather
ADMIN_ID=123456789                    # ton telegramId numérique (utilise @userinfobot)

# --- Mode d'exécution ---
# polling = pour dev local (pas besoin de domaine)
# webhook = pour prod (Hostinger avec domaine + SSL)
BOT_MODE=polling

# --- Webhook (uniquement si BOT_MODE=webhook) ---
WEBHOOK_DOMAIN=https://monshop.com    # ton domaine Hostinger avec SSL
WEBHOOK_PATH=/api/telegram/webhook
WEBHOOK_SECRET=change_moi_aleatoire   # token secret (header X-Telegram-Bot-Api-Secret-Token)
PORT=3000

# --- Base de données ---
# Dev (SQLite)
DATABASE_URL="file:./dev.db"
# Prod (MySQL Hostinger) — exemple :
# DATABASE_URL="mysql://user:password@srv.hostinger.com:3306/u123_shop"

# --- Wallets crypto ---
BTC_WALLET=bc1qexemple_remplace_par_ton_adresse_btc
LTC_WALLET=Lexemple_remplace_par_ton_adresse_ltc
